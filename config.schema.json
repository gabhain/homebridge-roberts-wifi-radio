{
  "pluginAlias": "RobertsRadioPlatform",
  "pluginType": "platform",
  "headerDisplay": "Homebridge Roberts Radio Settings",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Display Name",
        "type": "string",
        "default": "Roberts Radio"
      },
      "ip": {
        "title": "Radio IP Address",
        "type": "string",
        "default": "XX.XX.XX.XX"
      },
      "pin": {
        "title": "UNDOK PIN",
        "type": "string",
        "default": "1234"
      }
    },
    "required": [
      "name",
      "ip"
    ]
  }
}
